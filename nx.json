{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "main",
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "sharedGlobals": []
  },
  "targetDefaults": {
    "build": {
      "cache": true,
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "default",
        "^default"
      ],
      "outputs": [
        "{projectRoot}/dist"
      ]
    },
    "test": {
      "cache": true,
      "inputs": [
        "default",
        "^default"
      ]
    },
    "lint": {
      "cache": true,
      "inputs": [
        "default"
      ]
    },
    "e2e": {
      "cache": false
    },
    "dev": {
      "cache": false
    },
    "dev:ssl": {
      "cache": false
    },
    "dev:ssl:w": {
      "cache": false
    },
    "dev:ssl:cloud": {
      "cache": false
    },
    "dev:ssl:admin": {
      "cache": false
    }
  },
  "release": {
    "projects": [
      "vritti-cloud-server",
      "vritti-cloud-web"
    ],
    "projectsRelationship": "fixed",
    "version": {
      "conventionalCommits": true
    },
    "changelog": {
      "projectChangelogs": true,
      "workspaceChangelog": true
    }
  },
  "nxCloudId": "69b0162afa2a5349e3bf4f59"
}