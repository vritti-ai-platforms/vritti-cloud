{
  "name": "vritti-cloud-server",
  "projectType": "application",
  "sourceRoot": "apps/cloud-server/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run build",
        "cwd": "{projectRoot}"
      },
      "outputs": ["{projectRoot}/dist"],
      "cache": true
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run dev",
        "cwd": "{projectRoot}"
      },
      "cache": false
    },
    "dev:ssl": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run dev:ssl",
        "cwd": "{projectRoot}"
      },
      "cache": false
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run start",
        "cwd": "{projectRoot}"
      },
      "cache": false
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run lint",
        "cwd": "{projectRoot}"
      },
      "cache": true
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run test",
        "cwd": "{projectRoot}"
      },
      "cache": true
    },
    "db:generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run db:generate",
        "cwd": "{projectRoot}"
      },
      "cache": false
    },
    "db:push": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run db:push",
        "cwd": "{projectRoot}"
      },
      "cache": false
    },
    "db:migrate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run db:migrate",
        "cwd": "{projectRoot}"
      },
      "cache": false
    },
    "db:studio": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run db:studio",
        "cwd": "{projectRoot}"
      },
      "cache": false
    },
    "db:reset": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run db:reset",
        "cwd": "{projectRoot}"
      },
      "cache": false
    },
    "db:start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run db:start",
        "cwd": "{projectRoot}"
      },
      "cache": false
    },
    "db:stop": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run db:stop",
        "cwd": "{projectRoot}"
      },
      "cache": false
    }
  }
}
