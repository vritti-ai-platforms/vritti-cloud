{
  "name": "vritti-cloud",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "nx run-many --target=dev --projects=vritti-cloud-server,vritti-cloud-web --parallel",
    "dev:ssl": "nx run-many --target=dev:ssl --projects=vritti-cloud-server,vritti-cloud-web --parallel",
    "build": "nx run-many --target=build --all",
