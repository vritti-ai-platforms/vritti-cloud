    "check": "nx run-many --target=check --all",
    "graph": "nx graph",
    "release": "nx release"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.2",
    "@nx/js": "^20.8.4",
    "nx": "^20.0.0"
  }
}
