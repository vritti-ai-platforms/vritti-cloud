{
  "name": "vritti-cloud",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "nx run-many --target=dev --projects=vritti-cloud-server,vritti-cloud-web --parallel --output-style=stream",
    "dev:ssl": "nx run-many --target=dev:ssl --projects=vritti-cloud-server,vritti-cloud-web --parallel --output-style=stream",
    "dev:ssl:w": "nx run-many --target=dev:ssl:w --projects=vritti-cloud-server,vritti-cloud-web --parallel --output-style=stream",
    "dev:ssl:cloud": "nx run vritti-cloud-server:dev:ssl & nx run vritti-cloud-web:dev:ssl:cloud",
    "dev:ssl:admin": "nx run vritti-cloud-server:dev:ssl & nx run vritti-cloud-web:dev:ssl:admin",
    "build": "nx run-many --target=build --all",
    "lint": "nx run-many --target=lint --all",
    "test": "nx run-many --target=test --all",
    "test:e2e": "nx run-many --target=e2e --all",
    "check": "nx run-many --target=check --all",
    "graph": "nx graph",
    "release": "nx release",
    "db:generate": "nx run vritti-cloud-server:db:generate",
    "db:push": "nx run vritti-cloud-server:db:push",
    "db:migrate": "nx run vritti-cloud-server:db:migrate",
    "db:studio": "nx run vritti-cloud-server:db:studio",
    "db:reset": "nx run vritti-cloud-server:db:reset",
    "db:drop": "nx run vritti-cloud-server:db:drop",
    "db:start": "nx run vritti-cloud-server:db:start",
    "db:stop": "nx run vritti-cloud-server:db:stop",
    "db:generate:w": "nx run vritti-cloud-server:db:generate:w",
    "db:push:w": "nx run vritti-cloud-server:db:push:w",
    "db:migrate:w": "nx run vritti-cloud-server:db:migrate:w",
    "db:studio:w": "nx run vritti-cloud-server:db:studio:w",
    "db:reset:w": "nx run vritti-cloud-server:db:reset:w"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.2",
    "@nx/js": "^20.8.4",
    "nx": "^20.0.0"
  }
}
